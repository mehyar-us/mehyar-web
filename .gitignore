# Loop probe artifacts (untracked live-page captures from prior ticks;
# `curl -o <name>.html` into the repo root by mistake. Recurrence-prevention
# only — turn-041 hygiene sweep removed the existing strays).
*_live.html
mehyar_*.html
mehyar_*.xml
home_live.html
blog_live.html
mo_live*.html
nf.html
p_[0-9].html
micro-live-fresh.html
*.gz
# Probe bundle snapshots cached locally during probe-section-{H,J}.sh runs
.hermes/.probe-section-*-bundle.js
.hermes/.probe-section-*-home.html
# Loop probe artifacts in .hermes/probe/: reusable scripts (turn-NNN-*.py,
# extract-*.py, turn-NNN-body.txt) are committed and live in git; transient
# HTML snapshots from curl probes (e.g. home.html from turn-020) stay
# untracked locally.
.hermes/probe/*.html
.hermes/probe/*-live.html
# Loop audit artifacts: only the structured `.md` files and `learned.md` are
# legitimate loop records (committed for warm-start + audit-trail). Everything
# else in `.hermes/audit/` (HTML snapshots, JS bundle captures, PNGs, PR JSONs,
# telegram-card-*.txt) is transient working-tree noise from prior probe runs.
.hermes/audit/*
!.hermes/audit/*.md
!.hermes/audit/turn-*.md
# Loop probe artifacts (turn-051 hygiene): transient live-page captures,
# intermediate probe-M prefix caches, and one-shot investigation scripts that
# reference t-NNN-bundle.js by name. The reusable scripts live in `.hermes/probe/`
# (committed); these match the unversioned `.hermes/<...>-tNNN-*.{html,js,py}` shape.
.hermes/.probe-*-cited.*
.hermes/main-live-t*.js
.hermes/main-live-t*-after.js
.hermes/home-t*.html
.hermes/smoke-t*.html
.hermes/probe-turn-*-*.py
# Loop probe artifacts (turn-052 hygiene): root-level `main-*.js` captures
# from ad-hoc curl probes (e.g. `curl -o main-current.js https://mehyar.us/...`).
# The reusable probe scripts write to `.hermes/.probe-section-*-bundle.js`
# instead; root-level captures are working-tree noise from interrupted
# investigation scripts.
main-*.js
# Loop probe Section Q temp files (turn-059): repo-local curl `-o` cache.
# Used because the bash sandbox on this Windows + git-bash host silently
# drops `curl -o /tmp/...` flags (write-path safety filter), which made
# every Q run report `len=0` and FAIL the envelope check even when the
# live API was fine. Repo-local paths work; absolute /tmp paths don't.
.hermes/.probe-q-cache/
workers/mehyar-cron/worker-configuration.d.ts
