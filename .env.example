# Public browser configuration. Leave blank for same-origin Cloudflare Pages Functions.
VITE_MEHYARSOFT_API_BASE_URL=
# Optional owner-admin API origin. Leave blank to use https://api.mehyar.us.
VITE_MEHYARSOFT_ADMIN_API_BASE_URL=
VITE_TURNSTILE_SITE_KEY=

# Cloudflare Pages secret/env names used by functions; values are configured in Cloudflare, not committed.
# TURNSTILE_SECRET_KEY=
# HMAC_SECRET=
# ADMIN_SESSION_SECRET=
# MEHYARSOFT_ADMIN_USERNAME=
# MEHYARSOFT_ADMIN_EMAIL=
# MEHYARSOFT_ADMIN_PASSWORD=
# ALLOWED_ORIGINS=https://mehyar.us,https://www.mehyar.us
